# ==============================
# PRODUCTION
# Only updated via tagged commits
# ==============================
planly.work.gd, www.planly.work.gd {

	handle_errors {
		respond "Production deployment not available yet.

If you have just pushed a tagged release, wait 30 seconds and refresh.

If still not live, SSH into the VM and run:
docker compose -f ~/team-project/prd.yml up -d"
	}

	reverse_proxy http://teamproject-prd:8080
}

# ==============================
# DEVELOPMENT (optional but recommended)
# ==============================
dev.planly.work.gd {

	handle_errors {
		respond "Development deployment error.

If you have just pushed to main, wait 30 seconds and refresh.

If still not live, SSH into the VM and run:
docker compose -f ~/team-project/dev.yml up -d"
	}

	reverse_proxy http://teamproject-dev:8080
}